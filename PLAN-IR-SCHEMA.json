{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ser-kost.local/schemas/plan-ir/1.0.0",
  "title": "QGIS Cadastre Plan IR",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "project_id",
    "created_at",
    "crs",
    "ruleset",
    "idempotency_key",
    "steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "plan_id": {
      "type": "string",
      "minLength": 3
    },
    "project_id": {
      "type": "string",
      "minLength": 3
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "author": {
      "type": "string"
    },
    "intent_text": {
      "type": "string"
    },
    "crs": {
      "type": "string",
      "pattern": "^EPSG:[0-9]{4,6}$"
    },
    "ruleset": {
      "type": "string",
      "minLength": 3
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 8
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "failed",
        "done",
        "rolled_back"
      ]
    },
    "op": {
      "type": "string",
      "enum": [
        "fix",
        "split",
        "buffer",
        "difference",
        "intersection",
        "snap",
        "move",
        "merge",
        "clip",
        "validate",
        "commit",
        "rollback",
        "route",
        "variant_clone"
      ]
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "args": {
          "type": "object",
          "additionalProperties": true
        },
        "severity": {
          "type": "string",
          "enum": [
            "error",
            "warning"
          ],
          "default": "error"
        }
      }
    },
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_attempts",
        "backoff_ms"
      ],
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "backoff_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 60000
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "op",
        "inputs",
        "params",
        "prechecks",
        "postchecks",
        "idempotent",
        "retry",
        "status"
      ],
      "properties": {
        "step_id": {
          "type": "string",
          "pattern": "^s[0-9]+$"
        },
        "op": {
          "$ref": "#/$defs/op"
        },
        "inputs": {
          "type": "object",
          "additionalProperties": true
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        },
        "prechecks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/check"
          }
        },
        "postchecks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/check"
          }
        },
        "idempotent": {
          "type": "boolean"
        },
        "retry": {
          "$ref": "#/$defs/retry"
        },
        "on_error": {
          "type": "string",
          "enum": [
            "abort",
            "continue",
            "rollback"
          ],
          "default": "rollback"
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^s[0-9]+$"
          }
        }
      }
    }
  }
}
